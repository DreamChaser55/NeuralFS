fsif_version: "2.6"

mission_info:
  name: "Mission name string"
  author: "Author name string"
  description: "Mission description string"
  game_type: "single"
  flags: []
  ai_profile: "FS1 RETAIL"

environment:
  ambient_light_level: [255, 0, 0]
  suns: []
  starbitmaps: []
  nebula:
    enabled: false

player_setup:
  start_ship: "Alpha 1"
  extra_ships:
    - class: "GTF Ulysses"
      count: 4
  extra_weapons:
    - "Interceptor"

entities:
  ship_templates:
    alpha_fighter:
      class: "GTF Ulysses"
      team: "Friendly"
      weapons:
        primary: ["Avenger", "Avenger"]
        secondary: ["MX-50"]
  ships:
    - name: "GTC Fenris 1"
      class: "GTC Fenris"
      team: "Friendly"
      location: [200.0, 0.0, 800.0]
      arrival_cue: |
        ( true )
  wings:
    - name: "Alpha"
      template: "alpha_fighter"
      count: 4
      position: [0.0, 0.0, 0.0]
      arrival_cue: |
        ( true )
  waypoints: {}
  reinforcement_wings: []
  reinforcement_ships: []

mission_flow:
  command_briefing:
    stages: []
  briefing:
    stages: []
  debriefing:
    stages: []
  events: []
  goals: []
  messages: []
