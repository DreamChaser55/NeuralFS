$Formula: ( when
  ( <
    ( distance "Alpha 1" "GTI Ruins" )
    1000
  )
  ( send-message "Alpha 1" "Normal" "Look at that ruin" )
  ( send-message "GTT Argyll" "Normal" "GTI listening post" )
)

+Name: Human Ruins
+Objective:  XSTR("Investigate Ruins", -1)

$Formula: ( when
  ( has-docked-delay "GTT Argyll" "GTI Ruins" 1 5 )
  ( send-message "GTT Argyll" "Normal" "Found prototype" )
  ( send-message "GTD Stalwart" "Normal" "Bring it up" )
)

+Name: Discovery

$Formula: ( when
  ( has-arrived-delay 0 "Guardian" )
  ( send-message "Alpha 2" "High" "Shields holding" )
)

+Name: Guardian Attack
+Objective:  XSTR("Defend Argyll", -1)

$Formula: ( when
  ( and
     ( has-undocked-delay "GTT Argyll" "GTI Ruins" 1 0 )
     ( is-destroyed-delay 0 "Guardian" )
     ( is-destroyed-delay 0 "Hunter" )
  )
  ( send-message "GTT Argyll" "High" "Package secured" )
  ( add-goal "GTT Argyll" ( ai-warp-out 99 ) )
)

+Name: Extraction Complete

$Formula: ( when
  ( has-departed-delay 0 "GTT Argyll" )
  ( end-mission )
)

