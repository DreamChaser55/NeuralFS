#Debriefing_info

$Num stages: 2

$Formula: ( has-departed-delay 0 "GTT Argyll" )

$Multi text
    XSTR("The object you retrieved is a kinetic energy weapon. The 'Flail'. It seems GTI was experimenting with shield-piercing tech out here decades ago. Irony is, they never found a use for it. Until now. We can manufacture ammo for it. It should help punch through those Shivan hulls.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text

$Formula: ( is-destroyed-delay 0 "GTT Argyll" )

$Multi text
    XSTR("The Argyll is lost, and the prototype with it. We squandered our chance.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text


