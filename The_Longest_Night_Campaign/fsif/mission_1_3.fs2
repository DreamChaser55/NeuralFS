#Debriefing_info

$Num stages: 2

$Formula: ( has-departed-delay 0 "GTT Argyll" )

$Multi text
    XSTR("Outstanding work, Alpha. The tech boys are going crazy over this cargo. It's shield technology. They say they can retrofit our fighters within 24 hours. It won't be perfect, but it will give us a fighting chance against those black ships. You just leveled the playing field.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text

$Formula: ( is-destroyed-delay 0 "GTT Argyll" )

$Multi text
    XSTR("We lost the Argyll. And with it, our best chance at survival. The Stalwart is blind, deaf, and defenseless. Hope you're happy, pilot.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text


