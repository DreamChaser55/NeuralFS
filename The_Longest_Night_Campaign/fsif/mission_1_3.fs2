#Events		;! 8 total

$Formula: ( when
  ( has-time-elapsed 5 )
  ( send-message "Alpha 2" "Low" "Too quiet" )
  ( send-message "Alpha 1" "Normal" "Targets ahead" )
)

+Name: Quiet Arrival
+Objective:  XSTR("Destroy Sentry", -1)

$Formula: ( when
  ( is-destroyed-delay 0 "Sentry Gun" )
  ( send-message "#Command" "Normal" "Sentries down" )
)

+Name: Sentry Down
+Objective:  XSTR("Scan Containers", -1)

$Formula: ( when
  ( and
    ( is-cargo-known-delay 0 "Shivan Depot 1" )
    ( is-cargo-known-delay 0 "Shivan Depot 2" )
    ( is-cargo-known-delay 0 "Shivan Depot 3" )
  )
  ( send-message "#Command" "High" "Shields found" )
  ( send-message "#Command" "Normal" "Bring in Argyll" )
)

+Name: Scan Complete

$Formula: ( when
  ( has-docked-delay "GTT Argyll" "Shivan Depot 2" 1 0 )
  ( send-message "GTT Argyll" "Normal" "Jackpot" )
)

+Name: Argyll Docking
+Objective:  XSTR("Protect Argyll", -1)

$Formula: ( when
  ( has-arrived-delay 0 "Wrath" )
  ( send-message "#Command" "High" "Incoming" )
  ( send-message "GTT Argyll" "High" "Cant disconnect" )
)

+Name: Wrath Attack

$Formula: ( when
  ( has-undocked-delay "GTT Argyll" "Shivan Depot 2" 1 0 )
  ( send-message "GTT Argyll" "High" "Cargo secured" )
)

+Name: Argyll Undocking

$Formula: ( when
  ( and
    ( has-undocked-delay "GTT Argyll" "Shivan Depot 2" 1 0 )
    ( < ( distance "GTT Argyll" "Shivan Depot 2" ) 500 )
  )
  ( send-message "GTT Argyll" "Normal" "Departing" )
)

+Name: Argyll Departing

$Formula: ( when
  ( has-departed-delay 0 "GTT Argyll" )
  ( send-message "#Command" "Normal" "Good job" )
  ( end-mission )
)

+Name: Mission Complete
+Objective:  XSTR("Return to base", -1)

