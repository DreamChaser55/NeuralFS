#Debriefing_info

$Num stages: 2

$Formula: ( is-event-true-delay "Stalwart Jump" 0 )

$Multi text
    XSTR("The Crecy bought us the time we needed. Captain Haddock and his crew will be remembered. The Tenebris is disabled, but not destroyed. It will be back. But for now, we have some breathing room.", -1)
$end_multi_text
