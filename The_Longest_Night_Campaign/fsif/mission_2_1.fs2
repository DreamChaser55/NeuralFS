#Command Briefing

$Stage Text:
 XSTR("We are deep in the Laramis nebula now. The good news is, we have shields. We have the Flail.", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none

$Stage Text:
 XSTR("The bad news is, we are being hunted. A Lilith-class cruiser, designated SC Tenebris, has been tracking our ion trail.", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none

$Stage Text:
 XSTR("It's relentless. We can't outrun it. We have to fight. This is not going to be pretty. Prepare yourselves.", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none


