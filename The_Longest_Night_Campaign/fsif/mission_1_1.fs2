#Debriefing_info

$Num stages: 2

$Formula: ( is-event-true-delay "Stalwart Jump" 0 )

$Multi text
    XSTR("We made it. We're alive. The Stalwart has successfully jumped into the anomaly. Navigation is trying to figure out where the hell we are. Sensors are clearing... looks like a nebula. We've lost contact with Command. We've lost contact with everyone. Get some rest, pilot. It's going to be a long night.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text

$Formula: ( is-destroyed-delay 0 "GTD Stalwart" )

$Multi text
    XSTR("The Stalwart has been destroyed. You are stranded in deep space with no carrier and no way home. The Shivans are closing in...", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text


