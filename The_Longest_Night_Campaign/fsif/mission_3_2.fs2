$Multi text
    XSTR("The Stalwart is safe. The data on the Laramis node and the Flail weapon has been transferred to Command. You've done the impossible, pilot. You brought them home. The war isn't over. The Lucifer is still out there. But for tonight... we celebrate. Dismissed.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text

$Formula: ( is-destroyed-delay 0 "GTD Stalwart" )

$Multi text
    XSTR("The Stalwart was destroyed. Ross 128's last legacy has been erased. We have failed.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text


