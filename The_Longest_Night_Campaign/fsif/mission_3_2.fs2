  ( has-time-elapsed 5 )
  ( send-message "GTD Stalwart" "High" "Mayday" )
  ( send-message "Alpha 2" "High" "12 o'clock" )
)

+Name: Start Mayday
+Objective:  XSTR("Defend Stalwart", -1)

$Formula: ( when
  ( has-arrived-delay 0 "SC Tenebris" )
  ( send-message "GTD Stalwart" "High" "Cruiser Arrival" )
)

+Name: Tenebris Arrival

$Formula: ( when
  ( < ( hits-left "GTD Stalwart" ) 30 )
  ( send-message "GTD Stalwart" "High" "Hull Critical" )
)

+Name: Stalwart Damage Msg

$Formula: ( when
  ( has-arrived-delay 0 "GTD Galatea" )
  ( send-message "GTD Galatea" "High" "Galatea En Route" )
  ( send-message "Alpha 1" "High" "Saved" )
  ( send-message "GTD Galatea" "High" "Fire Battery" )
)

+Name: Galatea Arrival

$Formula: ( when
  ( is-destroyed-delay 0 "SC Tenebris" )
  ( send-message "GTD Galatea" "High" "Welcome Back" )
  ( send-message "GTD Stalwart" "High" "Not Yet" )
)

+Name: Tenebris Down

$Formula: ( when
  ( and
    ( is-destroyed-delay 0 "SC Tenebris" )
    ( is-destroyed-delay 0 "Rama" )
    ( is-destroyed-delay 0 "Krishna" )
    ( is-destroyed-delay 0 "Bheema" )
  )
  ( end-mission )
)

+Name: Mission End Success
+Objective:  XSTR("Mission Complete", -1)

#Goals		;! 3 total

$Type: Primary
+Name: Protect Stalwart Goal
$MessageNew:  XSTR("Protect the GTD Stalwart.", -1)
$end_multi_text
$Formula: ( and
   ( is-event-true-delay "Mission End Success" 0 )
   ( not ( is-destroyed-delay 0 "GTD Stalwart" ) )
)


$Type: Primary
+Name: Destroy Tenebris Goal
$MessageNew:  XSTR("Destroy the Shivan Pursuit Force (SC Tenebris).", -1)
$end_multi_text
$Formula: ( is-destroyed-delay 0 "SC Tenebris" )


$Type: Bonus
+Name: Stalwart Hull Bonus
$MessageNew:  XSTR("Keep Stalwart Hull above 20%.", -1)
$end_multi_text
$Formula: ( and
  ( is-event-true-delay "Mission End Success" 0 )
  ( > ( hits-left "GTD Stalwart" ) 20 )
)


