$multi_text
 XSTR("You need to scan the four bio-ports on the Malphas's hull. These are the points where the infection is being 'uploaded' to the ship.", -1)
$end_multi_text
$voice: none.wav
$camera_pos: 0.000000, 2000.000000, 0.000000
