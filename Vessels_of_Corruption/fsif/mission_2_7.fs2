#Command Briefing

$Stage Text:
 XSTR("The data from the Necromancer lab points to a massive Shivan presence in the Void's 'Lower Reaches.' We believe this is the command hub for the infection.", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none

$Stage Text:
 XSTR("Due to the density of the Shivan sensor net, we cannot send a wing. Alpha 1, you will go in alone using a specialized Loki with a reduced sensor profile.", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none

$Stage Text:
 XSTR("Your objective is to scan the SD Malphas, a Demon-class destroyer that appears to be the 'brood mother' for the infection in this sector. Do not engage.", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none


#Briefing
$start_briefing
$num_stages: 3
$start_stage
$multi_text
 XSTR("Alpha 1, the Malphas is anchored to a structure we've never seen before. It looks biological. Stay at low thrust; high engine output will flare their sensors.", -1)
$end_multi_text
