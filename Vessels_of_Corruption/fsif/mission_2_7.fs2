#Debriefing_info

$Num stages: 2

$Formula: ( and 
  ( is-event-true-delay "Ports Scanned" 0 ) 
  ( is-event-true-delay "Anchor Identified" 0 ) 
)

$Multi text
    XSTR("You survived the belly of the beast. The data you brought back confirms our worst fears. The Malphas is a transmitter. It's sending the 'Whisper' back to our fleet.", -1)
$end_multi_text
$Voice: none.wav
