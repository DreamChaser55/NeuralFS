#Events		;! 5 total

$Formula: ( every-time
  ( and
    ( > ( mission-time ) 60 )
    ( = ( mod ( mission-time ) 60 ) 0 )
  )
  ( hud-disable 5 )
  ( send-message "#Command" "High" "Whisper" )
)

+Name: Psychic Scream

$Formula: ( when
  ( and
    ( is-subsystem-destroyed-delay "GTSC Styx" "turret01" 0 )
    ( is-subsystem-destroyed-delay "GTSC Styx" "turret02" 0 )
    ( is-subsystem-destroyed-delay "GTSC Styx" "turret03" 0 )
    ( is-subsystem-destroyed-delay "GTSC Styx" "turret04" 0 )
  )
  ( do-nothing )
)

+Name: Bio-Spires Destroyed
+Objective:  XSTR("Destroy the 4 Bio-Spires on the GTSC Styx", -1)

$Formula: ( when
  ( < ( hits-left "GTSC Styx" ) 15 )
  ( change-subsystem-name "GTSC Styx" "science01a-solar1" "sensors" )
  ( send-message "Alpha 2" "High" "Heart revealed" )
)

+Name: Reveal Heart

$Formula: ( when
  ( is-cargo-known-delay 0 "GTSC Styx" )
  ( do-nothing )
)

+Name: Heart Scanned
