#Debriefing_info

$Num stages: 2

$Formula: ( is-destroyed-delay 0 "GTSC Styx" )

$Multi text
    XSTR("The Styx is gone. The rift has collapsed. But the data we recovered from the 'Heart' is terrifying. This wasn't just a ship; it was a blueprint. The Shivans are learning our anatomy to better dismantle it.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text

$Formula: ( not ( is-destroyed-delay 0 "GTSC Styx" ) )

$Multi text
    XSTR("The Styx survived. The hive has matured, and a Shivan fleet is emerging from the rift. Adhara is lost.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text


