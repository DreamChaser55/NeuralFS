$Multi text
    XSTR("We've escaped the Void, but the Erebus is a mess. We have Shivan organisms in the ventilation systems and half the crew is in quarantine.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text

$Formula: ( < ( hits-left "GTD Erebus" ) 10 )

$Multi text
    XSTR("The Erebus was boarded and over-run. The last transmission from the bridge was a single word: 'Beautiful.' The Void has claimed us all.", -1)
$end_multi_text
$Voice: none.wav
