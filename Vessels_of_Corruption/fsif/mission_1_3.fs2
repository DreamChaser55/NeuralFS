#Debriefing_info

$Num stages: 2

$Formula: ( is-event-true-delay "Aethelgard Disabled" 0 )

$Multi text
    XSTR("The Aethelgard is disabled. Our capture teams are reporting that the interior is... unrecognizable. The corridors are filled with a black, oily substance. But we have the ship.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text

$Formula: ( is-event-true-delay "Aethelgard Jumps" 0 )

$Multi text
    XSTR("The Aethelgard reached the node. If that thing reaches a populated system, the infection will spread. You had one job, Alpha.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text


