#Debriefing_info

$Num stages: 2

$Formula: ( is-goal-true-delay "Scan Pulsing Cargo" 0 )
$Multi text
    XSTR("The data you gathered is... unsettling. The Styx wasn't just destroyed; it was dismantled with surgical precision. The pulsing in those containers suggests biological contamination.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text

$Formula: ( is-goal-incomplete "Scan Pulsing Cargo" )
$Multi text
    XSTR("Without that data, we're flying blind. Adhara is becoming a graveyard, and we still don't know who the gravedigger is.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text


