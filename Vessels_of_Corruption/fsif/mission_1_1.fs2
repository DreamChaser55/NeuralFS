#Events		;! 9 total

$Formula: ( when
  ( is-cargo-known-delay 0 "Cluster 1" )
  ( do-nothing )
)

+Name: Cluster 1 Scanned

$Formula: ( when
  ( is-cargo-known-delay 0 "Cluster 2" )
  ( do-nothing )
)

+Name: Cluster 2 Scanned

$Formula: ( when
  ( is-cargo-known-delay 0 "Cluster 3" )
  ( do-nothing )
)

+Name: Cluster 3 Scanned

$Formula: ( when
  ( and
    ( is-cargo-known-delay 0 "Container 1" )
    ( is-cargo-known-delay 0 "Container 2" )
    ( is-cargo-known-delay 0 "Container 3" )
    ( is-cargo-known-delay 0 "Container 4" )
  )
  ( do-nothing )
)

+Name: Final Container Scanned

$Formula: ( when
  ( has-time-elapsed 10 )
  ( send-message "#Command" "High" "Too quiet" )
)

+Name: Msg: Too quiet
+Objective:  XSTR("Inspect debris clusters", -1)

$Formula: ( when
  ( < ( distance "Alpha 1" "Cluster 1" ) 500 )
  ( send-message "Alpha 2" "Normal" "Too quiet" )
)

+Name: Msg: Entering first cluster

$Formula: ( when
  ( or
    ( is-cargo-known-delay 0 "Container 1" )
    ( is-cargo-known-delay 0 "Container 2" )
    ( is-cargo-known-delay 0 "Container 3" )
    ( is-cargo-known-delay 0 "Container 4" )
  )
  ( send-message "#Command" "High" "Secondary signature" )
)

+Name: Msg: Pulsing cargo scan

$Formula: ( when
  ( or
    ( < ( distance "Alpha 1" "Container 1" ) 100 )
    ( < ( distance "Alpha 1" "Container 2" ) 100 )
    ( < ( distance "Alpha 1" "Container 3" ) 100 )
    ( < ( distance "Alpha 1" "Container 4" ) 100 )
  )
  ( send-message "Alpha 3" "Normal" "Breathing" )
)

+Name: Msg: Breathing

$Formula: ( when
  ( is-event-true-delay "Final Container Scanned" 0 )
  ( add-goal "Brahma" ( ai-chase-any 89 ) )
  ( send-message "#Command" "High" "Tactical update" )
)

