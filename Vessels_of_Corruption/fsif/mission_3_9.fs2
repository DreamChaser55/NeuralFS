	"Krishna 2"
	"Krishna 3"
	"Krishna 4"
)
$AI Goals: ( goals
( ai-chase "Adhara Orbital Hub" 89 )
)

#Events		;! 5 total

$Formula: ( when
  ( and
    ( is-destroyed-delay 0 "Seed 1" )
    ( is-destroyed-delay 0 "Seed 2" )
    ( is-destroyed-delay 0 "Seed 3" )
    ( is-destroyed-delay 0 "Seed 4" )
    ( is-destroyed-delay 0 "Seed 5" )
    ( is-destroyed-delay 0 "Seed 6" )
  )
  ( do-nothing )
)

+Name: All Seeds Destroyed
+Objective:  XSTR("Destroy all Shivan 'Seeds' before impact", -1)

$Formula: ( when
  ( or
    ( > ( get-object-z "Seed 1" ) 9000 )
    ( > ( get-object-z "Seed 2" ) 9000 )
    ( > ( get-object-z "Seed 3" ) 9000 )
    ( > ( get-object-z "Seed 4" ) 9000 )
    ( > ( get-object-z "Seed 5" ) 9000 )
    ( > ( get-object-z "Seed 6" ) 9000 )
  )
  ( do-nothing )
)

+Name: Impact Detected

$Formula: ( when
  ( or
    ( > ( get-object-z "Seed 1" ) 7000 )
    ( > ( get-object-z "Seed 2" ) 7000 )
    ( > ( get-object-z "Seed 3" ) 7000 )
    ( > ( get-object-z "Seed 4" ) 7000 )
    ( > ( get-object-z "Seed 5" ) 7000 )
    ( > ( get-object-z "Seed 6" ) 7000 )
  )
  ( send-message "#Command" "High" "Altitude warning" )
)

+Name: Critical Altitude

$Formula: ( when
  ( < ( hits-left "Adhara Orbital Hub" ) 90 )
  ( send-message "#Command" "High" "Hub screaming" )
)

+Name: Msg: Hub Help

$Formula: ( when
  ( has-time-elapsed 300 )
  ( send-message "#Command" "Normal" "Whisper plant" )
)

+Name: The Whisper Plant

#Goals		;! 3 total

$Type: Primary
+Name: Destroy Seeds
$MessageNew:  XSTR("Destroy all Shivan 'Seeds' before they enter the lower atmosphere.", -1)
$end_multi_text
$Formula: ( is-event-true-delay "All Seeds Destroyed" 0 )


$Type: Primary
+Name: Protect Hub
$MessageNew:  XSTR("Protect the Adhara Orbital Hub.", -1)
$end_multi_text
$Formula: ( not ( is-destroyed-delay 0 "Adhara Orbital Hub" ) )


$Type: Secondary
+Name: Destroy Seraphims
