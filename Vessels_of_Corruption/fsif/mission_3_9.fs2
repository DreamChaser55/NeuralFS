#Command Briefing

$Stage Text:
 XSTR("The GTD Erebus has returned to Adhara space, but we have brought the nightmare with us. The Shivan fleet has launched a full-scale assault on the colony.", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none

$Stage Text:
 XSTR("They are deploying 'Seeds'—colossal organic spores—into Adhara Prime's atmosphere. These Seeds contain biological agents designed to liquefy the ecosystem.", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none

$Stage Text:
 XSTR("We have heavy bombers capable of carrying the Harbinger nuclear bomb. You will use them to incinerate the Seeds before they can impact.", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none


#Briefing
$start_briefing
$num_stages: 3
$start_stage
$multi_text
 XSTR("Alpha, the Seeds are large and heavily armored. Your standard torpedoes won't work. You'll need to use the Harbingers. They take time to lock, so keep your distance.", -1)
$end_multi_text
