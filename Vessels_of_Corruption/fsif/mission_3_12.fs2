  ( is-destroyed-delay 0 "SD Malphas" ) 
  ( not ( has-departed-delay 0 "Alpha 1" ) ) 
)

$Multi text
    XSTR("You chose to stay. The last thing you saw was the white light of the core closing over you. You are a hero of the Alliance, but you are a ghost now.", -1)
$end_multi_text
$Voice: none.wav
