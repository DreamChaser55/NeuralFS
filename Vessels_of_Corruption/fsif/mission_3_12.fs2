    XSTR("The Adhara anomaly is gone. The Erebus, Admiral Kress, and the Malphas are all sealed within the Void forever. You are the only one who returned. The infection has been stopped.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text

