#Command Briefing

$Stage Text:
 XSTR("Following the destruction of the Styx hive, we have successfully stabilized the anomaly's core. The GTD Erebus is prepared to make the jump into the pocket we've designated 'The Void.'", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none

$Stage Text:
 XSTR("We are entering unknown territory. This pocket appears to be a Shivan nursery or shipyard, disconnected from the standard subspace network. Our goal is to locate the source of the infection.", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none

$Stage Text:
 XSTR("Upon arrival, expect the environment to be hostile. Your ship's computer has been updated with the latest sensor dampening filters, but expect glitches.", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none


#Briefing
$start_briefing
$num_stages: 3
$start_stage
$multi_text
 XSTR("This is it, Alpha. We're jumping the Erebus directly into the anomaly. We'll be blind for the first sixty seconds of transit.", -1)
$end_multi_text
$voice: none.wav
$camera_pos: 0.000000, 1500.000000, -250.000000
