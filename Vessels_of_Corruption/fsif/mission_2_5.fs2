$Name: Red world
$Team: -1
$MessageNew:  XSTR("I... I think I'm going to be sick. The stars... they're gone. It's just red. Everything is red.", -1)
$end_multi_text
+AVI Name: <None>

$Name: Spire Feed
$Team: -1
$MessageNew:  XSTR("Look at the Spires. They're not just turrets, they're... umbilical cords. They're feeding something.", -1)
$end_multi_text
+AVI Name: <None>

$Name: Use Banshee
$Team: -1
$MessageNew:  XSTR("Alpha, use your Banshee lasers to strip the Spires' shields. Your standard guns won't be as effective.", -1)
$end_multi_text
+AVI Name: <None>

