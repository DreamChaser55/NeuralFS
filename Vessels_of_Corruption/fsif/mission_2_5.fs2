#Debriefing_info

$Num stages: 2

$Formula: ( has-time-elapsed 600 )

$Multi text
    XSTR("We are in. The Void is... more vast than we imagined. The Erebus is holding together, but the crew is reporting auditory hallucinations. We need to find the GTI lab and get out of here.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text

$Formula: ( is-destroyed-delay 0 "GTD Erebus" )

$Multi text
    XSTR("The Erebus was lost during the transit. The infection has claimed our finest ship and her crew. Sol is now undefended from the horrors within the Void.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text


