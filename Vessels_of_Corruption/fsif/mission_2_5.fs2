$end_stage
$start_stage
$multi_text
 XSTR("Once we emerge, Alpha will fly point. We've detected three static signatures near the entry point. They look like the Spires we saw on the Styx. Take them out before the Erebus's shields can be targeted.", -1)
$end_multi_text
$voice: none.wav
$camera_pos: 500.000000, 1000.000000, 500.000000
$camera_orient:
	1.000000, 0.000000, 0.000000,
