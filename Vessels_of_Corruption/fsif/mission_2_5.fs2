$end_stage
$start_stage
$multi_text
 XSTR("Intelligence is issuing a new weapon for this mission—the Banshee laser. It's designed to puncture Shivan shields more effectively. You'll need it out there.", -1)
$end_multi_text
$voice: none.wav
$camera_pos: 0.000000, 2000.000000, 0.000000
