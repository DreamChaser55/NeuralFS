#Events		;! 7 total

$Formula: ( when
  ( has-time-elapsed 60 )
  ( do-nothing )
)

+Name: Transit Emergence
+Objective:  XSTR("Protect the GTD Erebus", -1)

$Formula: ( every-time
  ( and
    ( > ( mission-time ) 60 )
    ( = ( mod ( mission-time ) 60 ) 0 )
  )
  ( sabotage-subsystem "Alpha 1" "hull" 1 )
  ( hud-force-emp-effect 100 5000 "none" )
)

+Name: Subspace Bleed

$Formula: ( when
  ( and
    ( is-cargo-known-delay 0 "Bio-Spire 1" )
    ( is-cargo-known-delay 0 "Bio-Spire 2" )
    ( is-cargo-known-delay 0 "Bio-Spire 3" )
  )
  ( do-nothing )
)

+Name: Spires Scanned

$Formula: ( when
  ( is-cargo-known-delay 0 "Arjuna 1" )
  ( do-nothing )
)

+Name: Dragon Scanned

$Formula: ( when
  ( has-time-elapsed 65 )
  ( send-message "Alpha 2" "Normal" "Red world" )
)

+Name: Msg: Red world

$Formula: ( when
  ( < ( distance "Alpha 1" "Bio-Spire 1" ) 500 )
  ( send-message "Alpha 3" "Normal" "Spire Feed" )
)

+Name: Msg: Spire Feed

$Formula: ( when
  ( and
    ( has-time-elapsed 70 )
    ( not ( is-destroyed-delay 0 "Bio-Spire 1" ) )
  )
  ( send-message "#Command" "High" "Use Banshee" )
)

+Name: Banshee Demo Msg

