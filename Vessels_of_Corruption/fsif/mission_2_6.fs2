#Command Briefing

$Stage Text:
 XSTR("Intelligence has tracked an encrypted GTI signal to a facility moored deep within the Void. This is the heart of 'Project Necromancer.'", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none

$Stage Text:
 XSTR("Preliminary scans show the facility is a hybrid of Terran architecture and Shivan bio-matter. It is being used to process human subjects for 're-writing.'", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none

$Stage Text:
 XSTR("High Command has disavowed this facility. Your orders are to extract the research data and then sanitize the site. No one involved in this project can be allowed to return to GTA space.", -1)
$end_multi_text
$Ani Filename: <default>
+Wave Filename: none


#Briefing
$start_briefing
$num_stages: 3
$start_stage
$multi_text
 XSTR("Alpha, you'll clear the sentry guns. They are GTI-issue, but they've been modified with Shivan optics. They won't miss.", -1)
$end_multi_text
