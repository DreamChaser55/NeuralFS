#Debriefing_info

$Num stages: 2

$Formula: ( and 
  ( is-destroyed-delay 0 "GTSC Necromancer" ) 
  ( is-event-true-delay "Hubs Scanned" 0 ) 
)

$Multi text
    XSTR("The Necromancer is ashes. The data you recovered is being encrypted at Level Omega. We have the lead scientist in custody, though he hasn't stopped laughing since we boarded his ship.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text

$Formula: ( not ( is-destroyed-delay 0 "GTSC Necromancer" ) )

$Multi text
    XSTR("The data escaped. GTI's 'New Humans' are now one step closer to Sol. We cannot afford to let our own technology be turned against us in this way.", -1)
$end_multi_text
$Voice: none.wav
$Recommendation text:
    XSTR("", -1)
$end_multi_text


